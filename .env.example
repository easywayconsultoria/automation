# Public Supabase settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://oyqrrqvvlmajlcjugwpf.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key

# PostgreSQL. Use the pooled URL for the application and direct URL for migrations.
# Encode special characters in the password.
DATABASE_URL=postgresql://postgres.oyqrrqvvlmajlcjugwpf:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.oyqrrqvvlmajlcjugwpf:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Canonical public URL; localhost in development, Vercel URL in production.
APP_URL=http://localhost:3000

# Server-side rollout flag for OWNER/ADMIN layout governance.
LAYOUT_ADMIN_ENABLED=false
