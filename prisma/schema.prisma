generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ImportProcessStatus {
  DRAFT
  IN_REVIEW
  PENDING_ACTION
  COMPLIANT
  CLOSED
}

enum DocumentType {
  INVOICE
  PACKING_LIST
  CSV
  DECLARATION
  SUPPORT_DOC
  OTHER
}

enum DocumentSource {
  UPLOAD
  MANUAL
  GENERATED
}

enum DocumentStatus {
  UPLOADED
  PARSED
  FAILED
  REVIEWED
}

enum InconsistencySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InconsistencyStatus {
  OPEN
  ACCEPTED
  DISMISSED
  RESOLVED
}

enum DetectedBy {
  SYSTEM
  USER
}

enum ActionPlanStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum GeneratedBy {
  SYSTEM
  USER
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActionItemStatus {
  OPEN
  DOING
  DONE
}

enum DrawbackMode {
  ISENCAO
  SUSPENSAO
}

enum DrawbackStatus {
  DRAFT
  UNDER_REVIEW
  REGULAR
  IRREGULAR
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum ConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ConversationAttachmentKind {
  INVOICE
  PORTAL_UNICO_CSV
  DRAWBACK_CSV
  NOTE
  GENERATED_REPORT
  OTHER
}

enum ToolExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum SuggestedActionStatus {
  OPEN
  ACCEPTED
  DISMISSED
  COMPLETED
}

enum CsvImportStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum CsvLayoutType {
  PORTAL_UNICO
  DRAWBACK
}

enum RegistrationProposalStatus {
  DRAFT
  PENDING_REVIEW
  ACCEPTED
  DISMISSED
  CONVERTED
}

model UserProfile {
  id                            String                      @id @db.Uuid
  email                         String
  displayName                   String?                     @map("display_name")
  createdAt                     DateTime                    @default(now()) @map("created_at")
  updatedAt                     DateTime                    @updatedAt @map("updated_at")
  memberships                   WorkspaceMember[]
  owned                         Workspace[]                 @relation("WorkspaceOwner")
  auditLogs                     AuditLog[]                  @relation("AuditActor")
  createdProcesses              ImportProcess[]             @relation("ProcessCreator")
  uploadedDocuments             ProcessDocument[]           @relation("DocumentUploader")
  conversations                 Conversation[]              @relation("ConversationCreator")
  conversationMessages          ConversationMessage[]       @relation("ConversationMessageCreator")
  conversationAttachments       ConversationAttachment[]    @relation("ConversationAttachmentCreator")
  suggestedActionEvents         SuggestedActionEvent[]      @relation("SuggestedActionEventActor")
  createdRegistrationProposals  RegistrationProposal[]      @relation("RegistrationProposalCreator")
  reviewedRegistrationProposals RegistrationProposal[]      @relation("RegistrationProposalReviewer")
  registrationProposalEvents    RegistrationProposalEvent[] @relation("RegistrationProposalEventActor")

  @@map("user_profiles")
}

model Workspace {
  id                         String                      @id @default(uuid()) @db.Uuid
  name                       String
  ownerId                    String                      @unique @map("owner_id") @db.Uuid
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  owner                      UserProfile                 @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members                    WorkspaceMember[]
  auditLogs                  AuditLog[]
  importProcesses            ImportProcess[]
  processDocuments           ProcessDocument[]
  invoiceItems               InvoiceItem[]
  products                   ProductCatalog[]
  productAliases             ProductAlias[]
  inconsistencies            Inconsistency[]
  actionPlans                ActionPlan[]
  actionPlanItems            ActionPlanItem[]
  drawbackRecords            DrawbackRecord[]
  suppliers                  Supplier[]
  conversations              Conversation[]
  conversationMessages       ConversationMessage[]
  conversationAttachments    ConversationAttachment[]
  toolExecutions             ToolExecution[]
  suggestedActions           SuggestedAction[]
  suggestedActionEvents      SuggestedActionEvent[]
  portalCsvImports           PortalCsvImport[]
  portalCsvRows              PortalCsvRow[]
  drawbackCsvImports         DrawbackCsvImport[]
  drawbackCsvRows            DrawbackCsvRow[]
  csvLayouts                 CsvLayoutDefinition[]
  registrationProposals      RegistrationProposal[]
  registrationProposalEvents RegistrationProposalEvent[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model AuditLog {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String?      @map("workspace_id") @db.Uuid
  actorId     String?      @map("actor_id") @db.Uuid
  event       String
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor       UserProfile? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model ImportProcess {
  id                         String                      @id @default(uuid()) @db.Uuid
  workspaceId                String                      @map("workspace_id") @db.Uuid
  reference                  String
  clientName                 String                      @map("client_name")
  exporterName               String?                     @map("exporter_name")
  status                     ImportProcessStatus         @default(DRAFT)
  originCountry              String?                     @map("origin_country")
  incoterm                   String?
  invoiceNumber              String?                     @map("invoice_number")
  notes                      String?
  createdById                String                      @map("created_by") @db.Uuid
  supplierId                 String?                     @map("supplier_id") @db.Uuid
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  workspace                  Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy                  UserProfile                 @relation("ProcessCreator", fields: [createdById], references: [id])
  supplier                   Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  documents                  ProcessDocument[]
  items                      InvoiceItem[]
  inconsistencies            Inconsistency[]
  actionPlan                 ActionPlan?
  drawback                   DrawbackRecord?
  conversation               Conversation?
  conversationAttachments    ConversationAttachment[]
  toolExecutions             ToolExecution[]
  suggestedActions           SuggestedAction[]
  suggestedActionEvents      SuggestedActionEvent[]
  portalCsvImports           PortalCsvImport[]
  portalCsvRows              PortalCsvRow[]
  drawbackCsvImports         DrawbackCsvImport[]
  drawbackCsvRows            DrawbackCsvRow[]
  registrationProposals      RegistrationProposal[]
  registrationProposalEvents RegistrationProposalEvent[]

  @@unique([workspaceId, reference])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, supplierId])
  @@map("import_processes")
}

model ProcessDocument {
  id                      String                   @id @default(uuid()) @db.Uuid
  workspaceId             String                   @map("workspace_id") @db.Uuid
  importProcessId         String                   @map("import_process_id") @db.Uuid
  type                    DocumentType
  fileName                String                   @map("file_name")
  mimeType                String                   @map("mime_type")
  storagePath             String?                  @map("storage_path")
  source                  DocumentSource           @default(UPLOAD)
  uploadedById            String                   @map("uploaded_by") @db.Uuid
  uploadedAt              DateTime                 @default(now()) @map("uploaded_at")
  parsedAt                DateTime?                @map("parsed_at")
  status                  DocumentStatus           @default(UPLOADED)
  workspace               Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess           ImportProcess            @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  uploadedBy              UserProfile              @relation("DocumentUploader", fields: [uploadedById], references: [id])
  items                   InvoiceItem[]
  conversationAttachments ConversationAttachment[]
  portalCsvImports        PortalCsvImport[]
  drawbackCsvImports      DrawbackCsvImport[]

  @@index([workspaceId, importProcessId, uploadedAt])
  @@map("process_documents")
}

model InvoiceItem {
  id                    String                 @id @default(uuid()) @db.Uuid
  workspaceId           String                 @map("workspace_id") @db.Uuid
  importProcessId       String                 @map("import_process_id") @db.Uuid
  processDocumentId     String?                @map("process_document_id") @db.Uuid
  productCatalogId      String?                @map("product_catalog_id") @db.Uuid
  lineNumber            Int                    @map("line_number")
  supplierCode          String?                @map("supplier_code")
  description           String
  ncm                   String?
  quantity              Decimal                @db.Decimal(18, 6)
  unit                  String?
  unitPrice             Decimal                @map("unit_price") @db.Decimal(18, 6)
  totalPrice            Decimal                @map("total_price") @db.Decimal(18, 2)
  grossWeight           Decimal?               @map("gross_weight") @db.Decimal(18, 6)
  netWeight             Decimal?               @map("net_weight") @db.Decimal(18, 6)
  currency              String                 @default("USD")
  countryOfOrigin       String?                @map("country_of_origin")
  rawData               Json?                  @map("raw_data")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess         ImportProcess          @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  processDocument       ProcessDocument?       @relation(fields: [processDocumentId], references: [id], onDelete: SetNull)
  productCatalog        ProductCatalog?        @relation(fields: [productCatalogId], references: [id], onDelete: SetNull)
  inconsistencies       Inconsistency[]
  registrationProposals RegistrationProposal[]

  @@unique([importProcessId, lineNumber])
  @@index([workspaceId, importProcessId])
  @@index([workspaceId, productCatalogId])
  @@map("invoice_items")
}

model ProductCatalog {
  id           String         @id @default(uuid()) @db.Uuid
  workspaceId  String         @map("workspace_id") @db.Uuid
  internalCode String         @map("internal_code")
  description  String
  ncm          String?
  defaultUnit  String?        @map("default_unit")
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aliases      ProductAlias[]
  invoiceItems InvoiceItem[]

  @@unique([workspaceId, internalCode])
  @@index([workspaceId, active])
  @@map("product_catalog")
}

model ProductAlias {
  id                  String         @id @default(uuid()) @db.Uuid
  workspaceId         String         @map("workspace_id") @db.Uuid
  productCatalogId    String         @map("product_catalog_id") @db.Uuid
  supplierId          String?        @map("supplier_id") @db.Uuid
  supplierCode        String?        @map("supplier_code")
  supplierDescription String?        @map("supplier_description")
  confidenceHint      Decimal?       @map("confidence_hint") @db.Decimal(5, 4)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productCatalog      ProductCatalog @relation(fields: [productCatalogId], references: [id], onDelete: Cascade)
  supplier            Supplier?      @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([workspaceId, supplierCode])
  @@index([workspaceId, supplierId, supplierCode])
  @@map("product_aliases")
}

model Supplier {
  id             String          @id @default(uuid()) @db.Uuid
  workspaceId    String          @map("workspace_id") @db.Uuid
  name           String
  normalizedName String          @map("normalized_name")
  externalCode   String?         @map("external_code")
  country        String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  processes      ImportProcess[]
  aliases        ProductAlias[]

  @@unique([workspaceId, normalizedName])
  @@index([workspaceId, active, name])
  @@index([workspaceId, externalCode])
  @@map("suppliers")
}

model Inconsistency {
  id              String                @id @default(uuid()) @db.Uuid
  workspaceId     String                @map("workspace_id") @db.Uuid
  importProcessId String                @map("import_process_id") @db.Uuid
  invoiceItemId   String?               @map("invoice_item_id") @db.Uuid
  type            String
  severity        InconsistencySeverity
  title           String
  description     String
  detectedBy      DetectedBy            @default(SYSTEM) @map("detected_by")
  status          InconsistencyStatus   @default(OPEN)
  resolutionNote  String?               @map("resolution_note")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess   ImportProcess         @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  invoiceItem     InvoiceItem?          @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  actionItems     ActionPlanItem[]

  @@index([workspaceId, importProcessId, status, severity])
  @@map("inconsistencies")
}

model ActionPlan {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String           @map("workspace_id") @db.Uuid
  importProcessId String           @unique @map("import_process_id") @db.Uuid
  summary         String
  status          ActionPlanStatus @default(OPEN)
  generatedBy     GeneratedBy      @default(SYSTEM) @map("generated_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess   ImportProcess    @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  items           ActionPlanItem[]

  @@index([workspaceId, status])
  @@map("action_plans")
}

model ActionPlanItem {
  id                    String           @id @default(uuid()) @db.Uuid
  actionPlanId          String           @map("action_plan_id") @db.Uuid
  workspaceId           String           @map("workspace_id") @db.Uuid
  title                 String
  description           String
  priority              ActionPriority
  status                ActionItemStatus @default(OPEN)
  ownerUserId           String?          @map("owner_user_id") @db.Uuid
  dueDate               DateTime?        @map("due_date")
  sourceInconsistencyId String?          @map("source_inconsistency_id") @db.Uuid
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  actionPlan            ActionPlan       @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  workspace             Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceInconsistency   Inconsistency?   @relation(fields: [sourceInconsistencyId], references: [id], onDelete: SetNull)

  @@index([workspaceId, actionPlanId, status])
  @@map("action_plan_items")
}

model DrawbackRecord {
  id              String         @id @default(uuid()) @db.Uuid
  workspaceId     String         @map("workspace_id") @db.Uuid
  importProcessId String         @unique @map("import_process_id") @db.Uuid
  mode            DrawbackMode
  referenceCode   String?        @map("reference_code")
  status          DrawbackStatus @default(DRAFT)
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess   ImportProcess  @relation(fields: [importProcessId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@map("drawback_records")
}

model Conversation {
  id               String                   @id @default(uuid()) @db.Uuid
  workspaceId      String                   @map("workspace_id") @db.Uuid
  importProcessId  String                   @unique @map("import_process_id") @db.Uuid
  title            String?
  status           ConversationStatus       @default(ACTIVE)
  createdById      String                   @map("created_by") @db.Uuid
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  workspace        Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess    ImportProcess            @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  createdBy        UserProfile              @relation("ConversationCreator", fields: [createdById], references: [id])
  messages         ConversationMessage[]
  attachments      ConversationAttachment[]
  toolExecutions   ToolExecution[]
  suggestedActions SuggestedAction[]

  @@index([workspaceId, updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id             String                  @id @default(uuid()) @db.Uuid
  conversationId String                  @map("conversation_id") @db.Uuid
  workspaceId    String                  @map("workspace_id") @db.Uuid
  role           ConversationMessageRole
  content        String
  structuredData Json?                   @map("structured_data")
  createdById    String?                 @map("created_by") @db.Uuid
  createdAt      DateTime                @default(now()) @map("created_at")
  conversation   Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      UserProfile?            @relation("ConversationMessageCreator", fields: [createdById], references: [id], onDelete: SetNull)
  sourcedActions SuggestedAction[]       @relation("SuggestedActionSource")

  @@index([workspaceId, conversationId, createdAt])
  @@map("conversation_messages")
}

model ConversationAttachment {
  id                String                     @id @default(uuid()) @db.Uuid
  conversationId    String                     @map("conversation_id") @db.Uuid
  workspaceId       String                     @map("workspace_id") @db.Uuid
  importProcessId   String                     @map("import_process_id") @db.Uuid
  processDocumentId String?                    @map("process_document_id") @db.Uuid
  kind              ConversationAttachmentKind
  label             String
  storagePath       String?                    @map("storage_path")
  metadata          Json?
  createdById       String                     @map("created_by") @db.Uuid
  createdAt         DateTime                   @default(now()) @map("created_at")
  conversation      Conversation               @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace         Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess     ImportProcess              @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  processDocument   ProcessDocument?           @relation(fields: [processDocumentId], references: [id], onDelete: SetNull)
  createdBy         UserProfile                @relation("ConversationAttachmentCreator", fields: [createdById], references: [id])

  @@index([workspaceId, conversationId, createdAt])
  @@map("conversation_attachments")
}

model ToolExecution {
  id              String              @id @default(uuid()) @db.Uuid
  conversationId  String              @map("conversation_id") @db.Uuid
  workspaceId     String              @map("workspace_id") @db.Uuid
  importProcessId String              @map("import_process_id") @db.Uuid
  toolName        String              @map("tool_name")
  input           Json
  output          Json?
  criteria        Json?
  sources         Json?
  limitations     Json?
  status          ToolExecutionStatus @default(RUNNING)
  createdAt       DateTime            @default(now()) @map("created_at")
  completedAt     DateTime?           @map("completed_at")
  conversation    Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess   ImportProcess       @relation(fields: [importProcessId], references: [id], onDelete: Cascade)

  @@index([workspaceId, conversationId, createdAt])
  @@map("tool_executions")
}

model SuggestedAction {
  id              String                 @id @default(uuid()) @db.Uuid
  conversationId  String                 @map("conversation_id") @db.Uuid
  workspaceId     String                 @map("workspace_id") @db.Uuid
  importProcessId String                 @map("import_process_id") @db.Uuid
  type            String
  title           String
  description     String
  status          SuggestedActionStatus  @default(OPEN)
  sourceMessageId String?                @map("source_message_id") @db.Uuid
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  conversation    Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess   ImportProcess          @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  sourceMessage   ConversationMessage?   @relation("SuggestedActionSource", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  events          SuggestedActionEvent[]

  @@index([workspaceId, conversationId, status])
  @@map("suggested_actions")
}

model SuggestedActionEvent {
  id                String                @id @default(uuid()) @db.Uuid
  suggestedActionId String                @map("suggested_action_id") @db.Uuid
  workspaceId       String                @map("workspace_id") @db.Uuid
  importProcessId   String                @map("import_process_id") @db.Uuid
  fromStatus        SuggestedActionStatus @map("from_status")
  toStatus          SuggestedActionStatus @map("to_status")
  reason            String?
  actorId           String                @map("actor_id") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at")
  suggestedAction   SuggestedAction       @relation(fields: [suggestedActionId], references: [id], onDelete: Cascade)
  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess     ImportProcess         @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  actor             UserProfile           @relation("SuggestedActionEventActor", fields: [actorId], references: [id])

  @@index([workspaceId, suggestedActionId, createdAt])
  @@map("suggested_action_events")
}

model PortalCsvImport {
  id                    String                 @id @default(uuid()) @db.Uuid
  workspaceId           String                 @map("workspace_id") @db.Uuid
  importProcessId       String                 @map("import_process_id") @db.Uuid
  processDocumentId     String                 @unique @map("process_document_id") @db.Uuid
  csvLayoutId           String?                @map("csv_layout_id") @db.Uuid
  detectedVersion       String?                @map("detected_version")
  status                CsvImportStatus        @default(PROCESSING)
  header                Json?
  errors                Json?
  validRows             Int                    @default(0) @map("valid_rows")
  invalidRows           Int                    @default(0) @map("invalid_rows")
  processedAt           DateTime?              @map("processed_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  workspace             Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess         ImportProcess          @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  processDocument       ProcessDocument        @relation(fields: [processDocumentId], references: [id], onDelete: Cascade)
  csvLayout             CsvLayoutDefinition?   @relation(fields: [csvLayoutId], references: [id], onDelete: SetNull)
  rows                  PortalCsvRow[]
  registrationProposals RegistrationProposal[]

  @@index([workspaceId, importProcessId, status])
  @@map("portal_csv_imports")
}

model PortalCsvRow {
  id                 String          @id @default(uuid()) @db.Uuid
  portalCsvImportId  String          @map("portal_csv_import_id") @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  importProcessId    String          @map("import_process_id") @db.Uuid
  lineNumber         Int             @map("line_number")
  productCode        String          @map("product_code")
  description        String
  ncm                String?
  registrationStatus String          @map("registration_status")
  rawData            Json            @map("raw_data")
  portalCsvImport    PortalCsvImport @relation(fields: [portalCsvImportId], references: [id], onDelete: Cascade)
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess      ImportProcess   @relation(fields: [importProcessId], references: [id], onDelete: Cascade)

  @@index([workspaceId, importProcessId, productCode])
  @@map("portal_csv_rows")
}

model DrawbackCsvImport {
  id                String               @id @default(uuid()) @db.Uuid
  workspaceId       String               @map("workspace_id") @db.Uuid
  importProcessId   String               @map("import_process_id") @db.Uuid
  processDocumentId String               @unique @map("process_document_id") @db.Uuid
  csvLayoutId       String?              @map("csv_layout_id") @db.Uuid
  detectedVersion   String?              @map("detected_version")
  status            CsvImportStatus      @default(PROCESSING)
  header            Json?
  errors            Json?
  validRows         Int                  @default(0) @map("valid_rows")
  invalidRows       Int                  @default(0) @map("invalid_rows")
  processedAt       DateTime?            @map("processed_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  workspace         Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess     ImportProcess        @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  processDocument   ProcessDocument      @relation(fields: [processDocumentId], references: [id], onDelete: Cascade)
  csvLayout         CsvLayoutDefinition? @relation(fields: [csvLayoutId], references: [id], onDelete: SetNull)
  rows              DrawbackCsvRow[]

  @@index([workspaceId, importProcessId, status])
  @@map("drawback_csv_imports")
}

model DrawbackCsvRow {
  id                  String            @id @default(uuid()) @db.Uuid
  drawbackCsvImportId String            @map("drawback_csv_import_id") @db.Uuid
  workspaceId         String            @map("workspace_id") @db.Uuid
  importProcessId     String            @map("import_process_id") @db.Uuid
  lineNumber          Int               @map("line_number")
  referenceCode       String            @map("reference_code")
  productCode         String            @map("product_code")
  ncm                 String?
  grantedQuantity     Decimal           @map("granted_quantity") @db.Decimal(18, 6)
  usedQuantity        Decimal           @map("used_quantity") @db.Decimal(18, 6)
  availableBalance    Decimal           @map("available_balance") @db.Decimal(18, 6)
  unit                String?
  rawData             Json              @map("raw_data")
  drawbackCsvImport   DrawbackCsvImport @relation(fields: [drawbackCsvImportId], references: [id], onDelete: Cascade)
  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess       ImportProcess     @relation(fields: [importProcessId], references: [id], onDelete: Cascade)

  @@index([workspaceId, importProcessId, productCode])
  @@map("drawback_csv_rows")
}

model CsvLayoutDefinition {
  id              String              @id @default(uuid()) @db.Uuid
  workspaceId     String?             @map("workspace_id") @db.Uuid
  name            String
  type            CsvLayoutType
  version         String
  active          Boolean             @default(true)
  requiredColumns Json                @map("required_columns")
  optionalColumns Json                @map("optional_columns")
  expectedOrder   Json                @map("expected_order")
  validationRules Json                @map("validation_rules")
  aliases         Json?
  description     String
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  workspace       Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  portalImports   PortalCsvImport[]
  drawbackImports DrawbackCsvImport[]

  @@unique([workspaceId, type, version])
  @@index([type, active, version])
  @@map("csv_layout_definitions")
}

model RegistrationProposal {
  id                   String                      @id @default(uuid()) @db.Uuid
  workspaceId          String                      @map("workspace_id") @db.Uuid
  importProcessId      String                      @map("import_process_id") @db.Uuid
  portalCsvImportId    String?                     @map("portal_csv_import_id") @db.Uuid
  sourceItemId         String?                     @map("source_item_id") @db.Uuid
  suggestedProductCode String                      @map("suggested_product_code")
  suggestedDescription String                      @map("suggested_description")
  suggestedNcm         String?                     @map("suggested_ncm")
  status               RegistrationProposalStatus  @default(PENDING_REVIEW)
  rationale            String
  createdById          String                      @map("created_by") @db.Uuid
  reviewedById         String?                     @map("reviewed_by") @db.Uuid
  reviewedAt           DateTime?                   @map("reviewed_at")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  workspace            Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess        ImportProcess               @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  portalCsvImport      PortalCsvImport?            @relation(fields: [portalCsvImportId], references: [id], onDelete: SetNull)
  sourceItem           InvoiceItem?                @relation(fields: [sourceItemId], references: [id], onDelete: SetNull)
  createdBy            UserProfile                 @relation("RegistrationProposalCreator", fields: [createdById], references: [id])
  reviewedBy           UserProfile?                @relation("RegistrationProposalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  events               RegistrationProposalEvent[]

  @@unique([workspaceId, importProcessId, sourceItemId])
  @@index([workspaceId, importProcessId, status])
  @@map("registration_proposals")
}

model RegistrationProposalEvent {
  id                     String                     @id @default(uuid()) @db.Uuid
  registrationProposalId String                     @map("registration_proposal_id") @db.Uuid
  workspaceId            String                     @map("workspace_id") @db.Uuid
  importProcessId        String                     @map("import_process_id") @db.Uuid
  fromStatus             RegistrationProposalStatus @map("from_status")
  toStatus               RegistrationProposalStatus @map("to_status")
  changes                Json?
  reason                 String?
  actorId                String                     @map("actor_id") @db.Uuid
  createdAt              DateTime                   @default(now()) @map("created_at")
  registrationProposal   RegistrationProposal       @relation(fields: [registrationProposalId], references: [id], onDelete: Cascade)
  workspace              Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importProcess          ImportProcess              @relation(fields: [importProcessId], references: [id], onDelete: Cascade)
  actor                  UserProfile                @relation("RegistrationProposalEventActor", fields: [actorId], references: [id])

  @@index([workspaceId, registrationProposalId, createdAt])
  @@map("registration_proposal_events")
}
