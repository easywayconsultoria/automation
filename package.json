{
  "name": "easyway-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:status": "dotenv -e .env.local -- prisma migrate status",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run build"
  },
  "dependencies": {
    "@prisma/client": "6.16.3",
    "@supabase/ssr": "0.7.0",
    "@supabase/supabase-js": "2.57.4",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.10.0",
    "next": "15.5.9",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "22.18.6",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "autoprefixer": "10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.36.0",
    "eslint-config-next": "15.5.9",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "prisma": "6.16.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2"
  }
}
